# GrokHub backend configuration
# Copy to .env and fill in. All keys optional except those you enable.

# Core protocol
SSO_REFERRER=grok-build
BASE_URL=https://cli-chat-proxy.grok.com/v1
CLIENT_VERSION=0.2.93

# Database
DB_PATH=grokhub.db

# CPA export (local auth dir and/or remote Management API)
CPA_LOCAL_DIR=
CPA_MGMT_API_URL=
CPA_MGMT_API_KEY=

# grok2api (chenyme/grok2api — real Go gateway, deploy on its OWN port e.g. 8010)
# GROK2API_URL must point at the grok2api instance (NOT this GrokHub backend).
# GROK2API_KEY is a client key (g2a_xxx) created in grok2api Client Keys, NOT a raw OAuth token.
# GROK2API_IMPORT_PATH is the account-import management endpoint inside grok2api.
GROK2API_URL=http://127.0.0.1:8010
GROK2API_KEY=
GROK2API_IMPORT_PATH=/api/accounts
POOL_DEFAULT=ssoBasic

# Captcha: yescaptcha | sidecar
CAPTCHA_TYPE=yescaptcha
YESCAPTCHA_KEY=
SIDECAR_URL=http://127.0.0.1:8787

# Temp email providers (comma separated). Options: duckmail, mailtm, cloudflare, mailnest, cloudmail, yyds, cfd1
EMAIL_PROVIDERS=mailtm

# Per-provider env (only needed when you enable that provider):
# duckmail:    DUCKMAIL_API_BASE, DUCKMAIL_API_KEY
# cloudflare:  CLOUDFLARE_API_BASE, CLOUDFLARE_API_KEY, CLOUDFLARE_AUTH_MODE, DEFAULT_DOMAINS
# mailnest:    MAILNEST_API_KEY, MAILNEST_PROJECT_CODE
# cloudmail:   CLOUDMAIL_URL, CLOUDMAIL_ADMIN_EMAIL, CLOUDMAIL_PASSWORD
# yyds:        YYDS_API_BASE, YYDS_DEFAULT_DOMAIN
# cfd1:        CFD1_API_BASE, CFD1_ACCOUNT_ID, CFD1_D1_DB_ID, CFD1_API_TOKEN, CFD1_DOMAINS

# Server
BIND_HOST=127.0.0.1
BIND_PORT=8000

# Optional proxy for outbound registration requests
PROXY=
