# Sub2API is a model gateway used only by the Tiiextension native runtime.
# Do not copy these values into extension storage, browser scripts, prompts,
# task payloads, or committed configuration files.

# Base URL may include /v1 or omit it. HTTPS is required.
SUB2API_BASE_URL=https://sub2api.example.com/v1

# Store the real value in the native runtime secret store or user environment.
SUB2API_API_KEY=sk-replace-me

# Optional model enabled by your Sub2API group. Defaults to "auto".
SUB2API_MODEL=your-enabled-model
