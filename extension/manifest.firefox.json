{
  "manifest_version": 3,
  "name": "Tiiextension",
  "description": "Tiiextension browser and workspace agent with native filesystems, MCP bridge, and GPT tunnel control.",
  "version": "1.3.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "tiiextension@trepremium.online",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "activeTab",
    "cookies",
    "debugger",
    "downloads",
    "nativeMessaging",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:1807/*",
    "https://router.trepremium.online/*",
    "https://kiraai.vn/*",
    "https://api.therouter.ai/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_title": "Tiiextension",
    "default_popup": "src/popup.html"
  },
  "commands": {
    "open-agent-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Open Tiiextension side panel"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://router.trepremium.online:* https://kiraai.vn:* https://api.therouter.ai:*"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/chatgpt-content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
