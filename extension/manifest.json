{
  "manifest_version": 3,
  "name": "Tiiextension",
  "description": "Tiiextension browser and workspace agent with native filesystems, MCP bridge, and GPT tunnel control.",
  "version": "1.3.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "alarms",
    "cookies",
    "debugger",
    "downloads",
    "nativeMessaging",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:18401/*",
    "http://localhost:18401/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:20128/*",
    "http://localhost:20128/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://x.ai/*",
    "https://cli-chat-proxy.grok.com/*",
    "https://grok.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_title": "Tiiextension",
    "default_popup": "popup.html"
  },
  "commands": {
    "open-agent-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Open Tiiextension side panel"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://chatgpt.com https://x.ai https://cli-chat-proxy.grok.com https://grok.com https://*.grok.com"
  },
  "web_accessible_resources": [
    {
      "resources": ["pagepal-widget.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/pagepal-widget.js",
        "src/chatgpt-content.js"
      ],
      "run_at": "document_idle",
      "type": "module"
    },
    {
      "matches": [
        "https://xiaomimimo.com/*",
        "https://*.xiaomimimo.com/*",
        "https://kira.ai/*",
        "https://*.kira.ai/*"
      ],
      "js": [
        "src/pagepal-widget.js",
        "src/chatgpt-content.js"
      ],
      "run_at": "document_idle",
      "type": "module"
    },
    {
      "matches": [
        "https://freebuff.ai/*",
        "https://*.freebuff.ai/*",
        "https://freebuff.com/*",
        "https://*.freebuff.com/*"
      ],
      "js": [
        "src/pagepal-widget.js",
        "src/freebuff-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://agent.minimax.io/*",
        "https://www.minimax.io/*",
        "https://minimax.io/*"
      ],
      "js": [
        "src/pagepal-widget.js",
        "src/minimax-agent-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
    "https://designer.microsoft.com/*",
        "https://*.designer.microsoft.com/*",
        "https://deepai.org/*",
        "https://*.deepai.org/*",
        "https://felo.ai/*",
        "https://*.felo.ai/*"
      ],
      "js": [
        "src/pagepal-widget.js",
        "src/generic-web-provider-content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
